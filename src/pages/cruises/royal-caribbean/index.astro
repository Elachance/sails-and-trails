---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) =>
  !data.draft && data.category === 'cruise' && data.cruiseLine === 'royal-caribbean'
);
const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Royal Caribbean"
  description="Royal Caribbean trip reports and guides from years of sailing before kids — and what we'd do differently now."
>
  <div class="bg-gradient-to-br from-blue-900 to-blue-700 text-white py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <p class="text-blue-200 text-sm font-medium uppercase tracking-widest mb-3">Cruise guides</p>
      <h1 class="font-serif text-4xl md:text-5xl font-semibold mb-4">Royal Caribbean</h1>
      <p class="text-blue-100 text-lg leading-relaxed max-w-2xl">
        Where our cruise obsession started. Royal Caribbean did a lot of things right —
        the ships are spectacular engineering, the ports are well-chosen, and there's
        genuinely something for everyone. Here's what we learned.
      </p>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 py-16">
    {sorted.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sorted.map(post => <PostCard post={post} />)}
      </div>
    ) : (
      <div class="text-center py-16 text-gray-400">
        <div class="text-5xl mb-4">⚓</div>
        <p class="text-lg font-medium text-gray-600 mb-2">Posts coming soon</p>
        <p class="text-sm">Digging through the archives — Royal Caribbean guides dropping soon.</p>
      </div>
    )}
  </div>
</BaseLayout>
