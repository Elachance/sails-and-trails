---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-ocean-900 via-ocean-700 to-ocean-500 text-white py-24 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-ocean-200 text-sm font-medium uppercase tracking-widest mb-4">A family adventure blog</p>
      <h1 class="font-serif text-5xl md:text-6xl font-semibold leading-tight mb-6">
        Sails &amp; Trails
      </h1>
      <p class="text-ocean-100 text-xl leading-relaxed mb-10 max-w-2xl mx-auto">
        We're a multi-generational family of adventurers. Sometimes we're on a cruise ship in a concierge suite.
        Sometimes we're on a mountain trail with dehydrated food Barbara made herself.
        Always together — and always worth reading about.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/cruises/disney" class="bg-white text-ocean-800 font-semibold px-6 py-3 rounded-full hover:bg-ocean-50 transition-colors">
          🚢 Cruise Guides
        </a>
        <a href="/trails" class="border border-white/40 text-white font-semibold px-6 py-3 rounded-full hover:bg-white/10 transition-colors">
          🥾 Trail Adventures
        </a>
      </div>
    </div>
  </section>

  <!-- About teaser -->
  <section class="max-w-5xl mx-auto px-4 py-16 grid md:grid-cols-2 gap-12 items-center">
    <div>
      <p class="text-ocean-600 font-semibold text-sm uppercase tracking-wide mb-2">Who we are</p>
      <h2 class="font-serif text-3xl font-semibold mb-4">A family that goes places</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        I'm Bailey — cloud architect by day, detail-obsessed traveler always.
        My mother-in-law Barbara organizes our adventures, from Disney concierge suites
        to multi-week backpacking trips she's planned down to the last dehydrated meal.
        Together we've dragged two toddlers and an ever-expanding crew of extended family
        across the seas and up the mountains.
      </p>
      <p class="text-gray-600 leading-relaxed mb-6">
        This is our account of all of it — what to pack,
        what to expect, what surprised us, and what made us stare open-mouthed at the horizon.
      </p>
      <a href="/about" class="text-ocean-600 font-semibold hover:underline">Meet the whole crew →</a>
    </div>
    <div class="grid grid-cols-2 gap-3">
      <div class="col-span-2 rounded-2xl overflow-hidden aspect-video">
        <img
          src="/images/optimized/discovery-cove-jim-kids-hammock-laughing.jpg"
          alt="Jim laughing in a hammock with Rabbit and Raccoon at Discovery Cove"
          class="w-full h-full object-cover"
        />
      </div>
      <div class="rounded-2xl overflow-hidden aspect-square">
        <img
          src="/images/optimized/kids-rapunzel-character-meet-cruise.jpg"
          alt="Rabbit and Raccoon meeting Rapunzel on the Disney Wish"
          class="w-full h-full object-cover"
        />
      </div>
      <div class="rounded-2xl overflow-hidden aspect-square">
        <img
          src="/images/optimized/brevard-zoo-rabbit-balance-bridge-hero.jpg"
          alt="Rabbit on the treetop balance bridge at Brevard Zoo"
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- Recent posts -->
  {recentPosts.length > 0 && (
    <section class="max-w-5xl mx-auto px-4 pb-16">
      <h2 class="font-serif text-2xl font-semibold mb-8">Latest from the crew</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {recentPosts.map(post => <PostCard post={post} />)}
      </div>
    </section>
  )}

  <NewsletterForm />
</BaseLayout>
