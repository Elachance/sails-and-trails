---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, author, tags, category, cruiseLine, faqs } = post.data;

const canonicalURL = new URL(`/blog/${post.id}`, Astro.site);
const imageURL = heroImage ? new URL(heroImage, Astro.site).toString() : undefined;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  author: { '@type': 'Person', name: author },
  publisher: { '@type': 'Organization', name: 'Sails & Trails Family', url: 'https://sailsandtrailsfamily.com' },
  url: canonicalURL.toString(),
  ...(imageURL && { image: imageURL }),
};

const faqSchema = faqs?.length ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
} : null;

const categoryLabel = category === 'cruise'
  ? (cruiseLine === 'disney' ? 'Disney Cruise Line' : cruiseLine === 'royal-caribbean' ? 'Royal Caribbean' : 'Cruising')
  : category === 'trail' ? 'Trails & Hiking' : 'General';

const categoryColor = category === 'cruise' ? 'bg-ocean-100 text-ocean-700' : 'bg-trail-100 text-trail-700';
---

<BaseLayout title={title} description={description} image={heroImage}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="head" />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />}
  <article class="max-w-3xl mx-auto px-4 py-12">
    {heroImage && (
      <img
        src={heroImage}
        alt={title}
        class="w-full h-72 object-cover rounded-2xl mb-8 shadow-md"
      />
    )}

    <div class="flex items-center gap-3 mb-4">
      <span class={`text-xs font-semibold uppercase tracking-wide px-3 py-1 rounded-full ${categoryColor}`}>
        {categoryLabel}
      </span>
      {tags.map(tag => (
        <span class="text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded-full">#{tag}</span>
      ))}
    </div>

    <h1 class="font-serif text-4xl font-semibold leading-tight mb-4">{title}</h1>

    <div class="flex items-center gap-2 text-sm text-gray-500 mb-8 pb-8 border-b border-gray-100">
      <span>By {author}</span>
      <span>·</span>
      <time datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {updatedDate && (
        <>
          <span>·</span>
          <span>Updated <time datetime={updatedDate.toISOString()}>
            {updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time></span>
        </>
      )}
    </div>

    <div class="prose prose-lg prose-slate max-w-none
      prose-headings:font-serif prose-headings:font-semibold
      prose-a:text-ocean-600 prose-a:no-underline hover:prose-a:underline
      prose-img:rounded-xl prose-img:shadow-md">
      <slot />
    </div>
  </article>
</BaseLayout>
