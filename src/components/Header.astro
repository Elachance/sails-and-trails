---
const navLinks = [
  { href: '/cruises/disney', label: 'Disney Cruises' },
  { href: '/cruises/royal-caribbean', label: 'Royal Caribbean' },
  { href: '/trails', label: 'Trails' },
  { href: '/about', label: 'About Us' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-gray-100 bg-white/90 backdrop-blur-sm sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="text-2xl">⚓</span>
      <div class="leading-tight">
        <div class="font-serif text-lg font-semibold text-gray-900 group-hover:text-ocean-700 transition-colors">
          Sails &amp; Trails
        </div>
        <div class="text-xs text-gray-400 tracking-wide">family adventures</div>
      </div>
    </a>

    <nav class="hidden md:flex items-center gap-6">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`text-sm font-medium transition-colors hover:text-ocean-600 ${
            currentPath.startsWith(href) ? 'text-ocean-600' : 'text-gray-600'
          }`}
        >
          {label}
        </a>
      ))}
      <a
        href="/#newsletter"
        class="text-sm font-medium bg-ocean-600 text-white px-4 py-2 rounded-full hover:bg-ocean-700 transition-colors"
      >
        Subscribe
      </a>
    </nav>

    <!-- Mobile menu button (simple toggle, no JS framework needed) -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-gray-600"
      aria-label="Toggle menu"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
    <div class="max-w-5xl mx-auto px-4 py-3 flex flex-col gap-3">
      {navLinks.map(({ href, label }) => (
        <a href={href} class="text-sm font-medium text-gray-700 py-1">{label}</a>
      ))}
      <a href="/#newsletter" class="text-sm font-medium text-ocean-600 py-1">Subscribe to the newsletter</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
