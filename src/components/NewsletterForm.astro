---
// Using Kit (ConvertKit) for newsletter
// Replace YOUR_FORM_ID with your actual Kit form ID after signing up at kit.com
const KIT_FORM_ID = 'YOUR_FORM_ID';
---

<section id="newsletter" class="bg-ocean-900 text-white py-16 px-4">
  <div class="max-w-xl mx-auto text-center">
    <div class="text-4xl mb-4">⚓</div>
    <h2 class="font-serif text-3xl font-semibold mb-3">Don't miss a trip</h2>
    <p class="text-ocean-100 mb-8 leading-relaxed">
      Trip reports, packing lists, concierge secrets, and the occasional tale of what happens
      when you take three kids under six on a ship. No spam. Unsubscribe anytime.
    </p>

    <form
      action={`https://app.kit.com/forms/${KIT_FORM_ID}/subscriptions`}
      method="post"
      class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
    >
      <input
        type="email"
        name="email_address"
        placeholder="your@email.com"
        required
        class="flex-1 px-4 py-3 rounded-full text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-ocean-400"
      />
      <button
        type="submit"
        class="bg-sand-400 hover:bg-sand-200 text-gray-900 font-semibold px-6 py-3 rounded-full text-sm transition-colors whitespace-nowrap"
      >
        I'm in
      </button>
    </form>

    <p class="text-xs text-ocean-200 mt-4">Join the crew. Leave anytime.</p>
  </div>
</section>
